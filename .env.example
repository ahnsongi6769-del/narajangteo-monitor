# 공공데이터포털 인증키 — "Decoding 키"를 그대로 넣으세요. (requests가 자동으로 URL-인코딩 처리)
NARA_API_KEY=your_decoded_service_key_here

# Microsoft Teams Workflows 웹훅 URL
TEAMS_WEBHOOK_URL=https://prod-XX.koreacentral.logic.azure.com:443/workflows/...

# (선택) 디버그 모드 — 1이면 첫 응답 항목의 모든 필드를 stdout에 pretty JSON으로 dump
# 지역제한/업종 필드명을 확인할 때 사용
# DEBUG_DUMP=1
